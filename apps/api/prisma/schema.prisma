generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String                 @id @default(cuid())
  email              String                 @unique
  name               String?
  avatarUrl          String?
  locale             String?                @default("de")
  createdAt          DateTime               @default(now())
  deletedAt          DateTime?
  memberships        GroupMember[]
  expensesPaid       Expense[]              @relation("ExpensePayer")
  expenseParticipants ExpenseParticipant[]
  settlementsFrom    Settlement[]           @relation("SettlementFrom")
  settlementsTo      Settlement[]           @relation("SettlementTo")
  notificationPrefs  NotificationPreference[]
  webpush            WebpushSubscription[]
  auditLogs          AuditLog[]             @relation("AuditActor")
  invites            Invite[]
  dataExports        DataExportRequest[]
}

model Group {
  id          String        @id @default(cuid())
  name        String
  currency    String        @default("EUR")
  rounding    Int           @default(2)
  ownerId     String
  owner       User          @relation(fields: [ownerId], references: [id])
  createdAt   DateTime      @default(now())
  members     GroupMember[]
  expenses    Expense[]
  settlements Settlement[]
  auditLogs   AuditLog[]
  invites     Invite[]
}

model GroupMember {
  id        String   @id @default(cuid())
  groupId   String
  userId    String
  role      GroupRole @default(MEMBER)
  nickname  String?
  joinedAt  DateTime @default(now())
  group     Group    @relation(fields: [groupId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
}

enum GroupRole {
  OWNER
  ADMIN
  MEMBER
}

model Expense {
  id            String                @id @default(cuid())
  groupId       String
  payerId       String
  amount        Decimal               @db.Decimal(18, 4)
  currency      String
  date          DateTime
  category      String
  notes         String?
  splitType     SplitType
  createdBy     String
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  recurringRule String?
  group         Group                 @relation(fields: [groupId], references: [id])
  payer         User                  @relation("ExpensePayer", fields: [payerId], references: [id])
  participants  ExpenseParticipant[]
  receipts      Receipt[]
}

enum SplitType {
  EQUAL
  WEIGHTED
  SHARES
  FIXED
  PERCENT
}

model ExpenseParticipant {
  id          String   @id @default(cuid())
  expenseId   String
  userId      String
  share       Decimal? @db.Decimal(18, 4)
  weight      Decimal? @db.Decimal(18, 4)
  fixedAmount Decimal? @db.Decimal(18, 4)
  percent     Decimal? @db.Decimal(18, 4)
  expense     Expense  @relation(fields: [expenseId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  @@unique([expenseId, userId])
}

model Receipt {
  id        String   @id @default(cuid())
  expenseId String
  url       String
  mime      String
  size      Int
  ocrText   String?
  createdAt DateTime @default(now())
  expense   Expense  @relation(fields: [expenseId], references: [id])
}

model Settlement {
  id          String        @id @default(cuid())
  groupId     String
  fromUserId  String
  toUserId    String
  amount      Decimal       @db.Decimal(18, 4)
  currency    String
  status      SettlementStatus @default(OPEN)
  createdAt   DateTime       @default(now())
  confirmedAt DateTime?
  group       Group         @relation(fields: [groupId], references: [id])
  fromUser    User          @relation("SettlementFrom", fields: [fromUserId], references: [id])
  toUser      User          @relation("SettlementTo", fields: [toUserId], references: [id])
}

enum SettlementStatus {
  OPEN
  SENT
  CONFIRMED
  POSTED
}

model NotificationPreference {
  id       String            @id @default(cuid())
  userId   String
  channel  NotificationChannel
  type     String
  enabled  Boolean          @default(true)
  user     User             @relation(fields: [userId], references: [id])

  @@unique([userId, channel, type])
}

enum NotificationChannel {
  EMAIL
  PUSH
}

model AuditLog {
  id        String   @id @default(cuid())
  groupId   String
  actorId   String
  action    String
  meta      Json
  createdAt DateTime @default(now())
  group     Group    @relation(fields: [groupId], references: [id])
  actor     User     @relation("AuditActor", fields: [actorId], references: [id])
}

model Invite {
  id         String   @id @default(cuid())
  groupId    String
  email      String
  role       GroupRole
  token      String   @unique
  expiresAt  DateTime
  acceptedAt DateTime?
  group      Group    @relation(fields: [groupId], references: [id])
  user       User?    @relation(fields: [email], references: [email])
}

model WebpushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  auth      String
  p256dh    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model DataExportRequest {
  id        String           @id @default(cuid())
  userId    String
  status    DataExportStatus @default(REQUESTED)
  url       String?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id])
}

enum DataExportStatus {
  REQUESTED
  READY
  EXPIRED
}
